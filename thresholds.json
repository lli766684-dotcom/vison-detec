{
  "image": {
    "max_image_side": 1024,
    "min_refund_images": 1
  },
  "quality": {
    "blur_var_threshold": 35.0,
    "dark_mean_threshold": 28.0
  },
  "evidence_rules": {
    "required_shot_types_min": [
      "overview",
      "damage_with_merchant"
    ],
    "recommended_shot_types": [
      "damage_closeup",
      "merchant_label_closeup",
      "auxiliary"
    ],
    "frontend_block_on_missing_required": true,
    "backend_fail_on_missing_required": true
  },
  "similarity": {
    "sim_high": 0.78,
    "sim_mid": 0.6,
    "sim_low": 0.42,
    "group_prior": {
      "expected": 0.05,
      "neutral": 0.0,
      "negative": -0.04
    },
    "conflict_margin": 0.08
  },
  "aggregation": {
    "agg_fail_ratio": 0.5,
    "agg_warn_ratio": 0.3
  },
  "risk": {
    "status_to_risk": {
      "pass": "low",
      "warn": "medium",
      "fail": "high"
    }
  }
}
